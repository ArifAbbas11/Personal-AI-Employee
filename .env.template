# AI Employee Docker Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to Git!

# PostgreSQL Configuration
POSTGRES_PASSWORD=change_me_in_production

# Odoo Configuration
ODOO_URL=http://odoo:8069
ODOO_DB=postgres
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# Gmail API (paths to mounted secrets)
GMAIL_CREDENTIALS_PATH=/secrets/credentials.json
GMAIL_TOKEN_PATH=/secrets/token.pickle

# WhatsApp
WHATSAPP_SESSION_PATH=/secrets/whatsapp_session

# LinkedIn API Credentials
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# Twitter API Credentials
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# LLM Backend Configuration (Hybrid Approach)
# Options: ollama (local, free) or groq (cloud, free)
LLM_BACKEND=ollama

# Ollama Configuration (for local development)
# Use WSL2 IP address or localhost
OLLAMA_HOST=172.20.119.127

# Groq Configuration (for cloud deployment - FREE!)
# Get your free API key at: https://console.groq.com
# Free tier: 14,400 requests/day, very fast inference
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Logging
LOG_LEVEL=INFO
LOG_PATH=/app/logs

# Vault
VAULT_PATH=/vault
